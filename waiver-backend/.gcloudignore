test.js
sample-payload.json
bad-payload-missing-ack.json
bad-payload-signature-mismatch.json

# QR generator: a one-time local tool, not runtime code.
# Its qrcode dependency is a devDependency for the same
# reason — see package.json.
generate-qr.js
waiver-qr.svg

node_modules
